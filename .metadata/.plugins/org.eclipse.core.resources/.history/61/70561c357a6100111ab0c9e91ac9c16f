#include "uart_ttl.h"
#include <string.h>
#include <stdio.h>

#define BUF_SIZE 128

void uart_ttl_init(UART_HandleTypeDef *huart) {
    char msg[] = "NUCLEO Ready!\r\n";
    HAL_UART_Transmit(huart,
                      (uint8_t*)msg,
                      strlen(msg),
                      HAL_MAX_DELAY);
}

void uart_ttl_send(UART_HandleTypeDef *huart,
                   const char *msg) {
    HAL_UART_Transmit(huart,
                      (uint8_t*)msg,
                      strlen(msg),
                      HAL_MAX_DELAY);
}

void uart_ttl_receive(UART_HandleTypeDef *huart) {
    uint8_t buf[BUF_SIZE];
    uint8_t ch = 0;
    uint8_t idx = 0;

    while (1) {
        HAL_StatusTypeDef ret;
        ret = HAL_UART_Receive(huart,
                               &ch, 1, 100);
        if (ret == HAL_OK) {
            buf[idx++] = ch;
            if (ch == '\n' || ch == '\r'
                || idx >= BUF_SIZE - 1) {
                buf[idx] = '\0';
                char reply[BUF_SIZE + 32];
                snprintf(reply, sizeof(reply),
                         "Received: %s\r\n",
                         buf);
                HAL_UART_Transmit(
                    huart,
                    (uint8_t*)reply,
                    strlen(reply),
                    HAL_MAX_DELAY);
                idx = 0;
                break;
            }
        } else {
            break;
        }
    }
}
